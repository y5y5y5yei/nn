<mujoco model="simple_humanoid">
  <compiler angle="radian" />
  <option timestep="0.01" gravity="0 0 -9.81" />

  <worldbody>
    <!-- 地面 -->
    <geom name="ground" type="plane" size="10 10 0.1" rgba="0.8 0.8 0.8 1"/>

    <!-- 躯干，重心抬高，直立设置 -->
    <body name="torso" pos="0 0 1.0">
      <geom type="capsule" size="0.15 0.3" fromto="0 0 -0.3 0 0 0.3" rgba="0.2 0.6 1 1"/>

      <!-- 头部 -->
      <body name="head" pos="0 0 0.4">
        <geom type="sphere" size="0.12" rgba="0.9 0.7 0.5 1"/>
      </body>

      <!-- 右臂 -->
      <body name="right_arm" pos="0.15 0 0.1">
        <joint name="r_shoulder" type="hinge" axis="0 1 0" range="-1.57 1.57" damping="0.1"/>
        <geom type="capsule" size="0.04 0.2" fromto="0 0 0 0.25 0 0" rgba="0.9 0.9 0.9 1"/>
      </body>

      <!-- 左臂 -->
      <body name="left_arm" pos="-0.15 0 0.1">
        <joint name="l_shoulder" type="hinge" axis="0 1 0" range="-1.57 1.57" damping="0.1"/>
        <geom type="capsule" size="0.04 0.2" fromto="0 0 0 -0.25 0 0" rgba="0.9 0.9 0.9 1"/>
      </body>

      <!-- 右腿 -->
      <body name="right_leg" pos="0.1 -0.05 -0.35">
        <joint name="r_hip" type="hinge" axis="0 1 0" range="-0.5 0.5" damping="0.1"/>
        <geom type="capsule" size="0.06 0.25" fromto="0 0 0 0 0 -0.3" rgba="0.9 0.9 0.9 1"/>
        <body name="right_shin" pos="0 0 -0.3">
          <joint name="r_knee" type="hinge" axis="0 1 0" range="-2.5 0" damping="0.1"/>
          <geom type="capsule" size="0.05 0.25" fromto="0 0 0 0 0 -0.3" rgba="0.9 0.9 0.9 1"/>
          <body name="right_foot" pos="0 0 -0.3">
            <geom type="box" size="0.08 0.05 0.03" rgba="0.6 0.6 0.6 1"/>
          </body>
        </body>
      </body>

      <!-- 左腿 -->
      <body name="left_leg" pos="-0.1 -0.05 -0.35">
        <joint name="l_hip" type="hinge" axis="0 1 0" range="-0.5 0.5" damping="0.1"/>
        <geom type="capsule" size="0.06 0.25" fromto="0 0 0 0 0 -0.3" rgba="0.9 0.9 0.9 1"/>
        <body name="left_shin" pos="0 0 -0.3">
          <joint name="l_knee" type="hinge" axis="0 1 0" range="-2.5 0" damping="0.1"/>
          <geom type="capsule" size="0.05 0.25" fromto="0 0 0 0 0 -0.3" rgba="0.9 0.9 0.9 1"/>
          <body name="left_foot" pos="0 0 -0.3">
            <geom type="box" size="0.08 0.05 0.03" rgba="0.6 0.6 0.6 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>